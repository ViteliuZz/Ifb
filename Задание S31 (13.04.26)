S31 (1б) Создайте текстовый массив с названиями цифр от 0 до 9. Пользователь вводит число и получает на экран его название.
#include <iostream>
#include <fstream>
using namespace std;
int main(){
    int number;
    setlocale(0,"Russian");
    string names[]={"Ноль","Один","Два","Три",
                    "Четыре","Пять","Шесть","Семь"
                    "Восемь","Двевять"};
    cout << "Введите нужное число: ";
    cin >> number;
    if (number>0 || number<10){
        cout <<"Название заданной цифры: ";
        cout << names[number];
    }else{
        cout << "Задана не цифра";}
return 0;
}
