using namespace std;

int main(){
    setlocale(0,"Russian");
    int a,b,d;
    cout << "Введите число А: ";
    cin >> a;
    b=10*a-7;
    d=a*a-2*a+1;
    if (b>d){
        cout << "10A+7 = " << b << '\n';
        cout << "A^2-2A+1 = " << d << '\n';
        cout << "10А+7 > A^2-2A+1";
    }else{
        cout << "10A+7 = " << b << '\n';
