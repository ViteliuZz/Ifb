///////////////////M01 (3б) Используя циклы выведите таблицу Пифагора. Она должна быть отформатирована (используйте символ табуляции).
#include <iostream>
using namespace std;
int main()
{
    int a,b,c,k;
    c=0;
    a=0;
    k=0;
    b=1;
    while (k<=9){
        //cout << "1";
        while (c<=9){
            a=a+1; // ввод в строку
            cout <<" "<<a*b; 
            c=c+1; // счетчик внетреннего цикла
        }
        cout <<'\n';
        b=b+1; // множитель/номер строки в таблице
        k=k+1; // счетчик внешнего цикла
        c=0; // обнуление для корректной работы внутреннего цикла
        a=0;
    }
    return 0;
}

########################### Если важно оформление таблицы, то можно сделать так:

#include <iostream>
using namespace std;
int main()
{
    int a,b,c,k,count,v;
    c=0;
    a=0;
    k=0;
    b=1;
    v=0;
    while (k<=9){
        if (v!=1){ // отдельный цикл для верхнего оформления
            for (count=1; count<= 10; count=count+1)
                cout <<count<<" ";
            cout <<'\n';
            v=v+1;
        }else{
            cout<<b;  // боковое оформление таблицы
            while(c<=9){
                a=a+1; // ввод в строку
                cout<<" "<<a*b;
                c=c+1; // счётчик внутреннего цикла
            }
            cout<<'\n';
            b=b+1; // множитель/номер строки в таблице
            k=k+1; // счётчик внешнего цикла
            c=0; // обнуление для корректной работы внутреннего цикла
            a=0; // обнуление чисел строки
        }
    }
    return 0;
}


/////////////////// М02 (3б) Функция принимает два параметра: сторона А и число сторон N, и должна вернуть площадь N-угольника со стороной А.

#include <iostream>
#include <cmath>
using namespace std;
int main()
{
    setlocale(0,"Russian");
    float A,N; // Использовал float, так как стороны треугольника не всегда целые числа
    float S; // Использовал float, чтобы не было округления площади в результате
    // Если нужна выше точность, то можно double использовать
    A=0;
    N=4;
    S=0;
    while(N>=3){
        cout <<"Введите сторону многоугольника: " ;
        cin >> A;
        cout << "Введите количество сторон многоугольника: ";
        cin >> N;
        if (N<3){
            cout << "Количество сторон меньше 3";
        }else{
            S=(N*(A*A))/(4*tan(M_PI/N)); // M_PI - это число пи в C++ из библиотеки cmath
            cout << "Площадь треугольника с длиной " << A
            << " и " << N << " числом сторон равна: " << S;
            cout << '\n';
        }
    }
    return 0;
}



