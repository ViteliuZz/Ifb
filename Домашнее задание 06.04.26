H01 (4б) Напишите функцию расчета синуса, используя его представление в виде ряда: Ограничьтесь первыми 10-ю членами ряда

Исходил из формулы n-го члена ряда Маклорена для синуса: (-1)^2n-1 * x^2n-1/2n-1!



#include <iostream>
#include <cmath>
using namespace std;

int main()
{
    setlocale(0,"Russian");
    double fact,s,k,x;
    int n,l,i,m;
    n=1;
    k=0;
    x=1;
    l=0;
    i=0;
    s=0;
    cout << "Введите значение x (в радианах): ";
    cin >> x;
    // Задаем диапазон x в [ pi , -pi ], иначе неправильно считает
    // fmod - достаток от деления для чисел с точкой (% не работает)
    // M_PI - число пи из библиотеки cmath
    x=fmod(x,2*M_PI);
    if (x>M_PI) x-=2*M_PI;
    if (x<-M_PI) x+=2*M_PI;
    while(l<=10) {
        fact=1;
        m=2*n-1;
        // цикл для факториалов
        for(i=1; i<=m; i=i+1) {
            fact=fact*i;
        }
        // Члены ряда
        // pow - возведение в степень в С++
        s=pow(-1, n-1)*pow(x, m)/fact;
        // Сумматор членов ряда
        k=s+k;
        // Степени синуса
        n=n+2;
        // Счетчик цикла (10 членов ряда)
        l=l+1;
    }
    cout << "Сумма ряда: " << k << '\n';
    cout << "Значение sin("<<x<<") от заданного числа: " << sin(x);
    return 0;
}
