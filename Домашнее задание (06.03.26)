S12 (1б) Используя другой тип цикла, перебрать числа от 1 до 1000 с шагом 4. Найти сумму всех чисел, которые делятся на 7 без остатка

#include <iostream>

using namespace std;

int main(){
    setlocale(0,"Russian");
    int i,k;
    k=0;
    for(i=0; i<=1000; i=i+4){
        if (i%7==0){
            k=k+i;
        }
        // Вывод всех чисел для утверждения в шаге +4
        cout << i << " ";
    }
    // Ввел отступ, чтобы числа не слиплись с суммой
    cout << '\n';
    cout << k << '\n';
return 0;
}


