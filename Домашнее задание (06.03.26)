#include <iostream>

using namespace std;

int main(){
    setlocale(0,"Russian");
    int a,b,k,d;
    cout << "Введите число А: ";
    cin >> a;
    cout << "Введите число B: ";
    cin >> b;
    if (b==0){
        cout << "На ноль делить нельзя";
        return 0;
    }
    k=a%b;
    cout << "Вывод остатка от деления: " << a << " % " << b << " = " << k << '\n';
