S11 (1б) Циклически перебрать числа от 0 до 100. Если число делится на 3 вывести его на экран:
#include <iostream>

using namespace std;

int main(){
    setlocale(0,"Russian");
    int c;
    c=0;
    while (c!=100){
        c=c+1;
        if (c%3==0){
            cout << "Число, делящееся на 3: " << c << '\n';
        }
    }
return 0;
}


